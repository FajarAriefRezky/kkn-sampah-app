{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300,
        "includeFiles": "uploads/**",
        "excludeFiles": "certs/**,.wwebjs*"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ],
  "env": {
    "PORT": "3000",
    "HOST": "0.0.0.0",
    "NODE_ENV": "production",
    "FORCE_LOCAL_HTTPS": "0"
  }
}

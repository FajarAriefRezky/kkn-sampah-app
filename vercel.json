{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ],
  "env": {
    "PORT": "3000",
    "HOST": "0.0.0.0",
    "NODE_ENV": "production"
  },
  "functions": {
    "src/server.js": {
      "maxDuration": 300
    }
  }
}
